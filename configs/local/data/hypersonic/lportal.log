cale]}</option>\u000a\u0009\u0009\u0009[/#list]\u000a\u0009\u0009</select>\u000a\u0009\u0009[#if input.errorMessage?has_content]\u000a\u0009\u0009\u0009<p class="font-weight-semi-bold mt-1 text-danger" id="${fragmentEntryLinkNamespace}-select-input-error-message">\u000a\u0009\u0009\u0009\u0009<svg class="lexicon-icon lexicon-icon-info-circle" focusable="false" role="presentation">\u000a\u0009\u0009\u0009\u0009\u0009<use xlink:href="${siteSpritemap}#info-circle" />\u000a\u0009\u0009\u0009\u0009</svg>\u000a\u0009\u0009\u0009\u0009<span>\u000a\u0009\u0009\u0009\u0009\u0009${input.errorMessage}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</p>\u000a\u0009\u0009[/#if]\u000a\u0009\u0009[#if input.showHelpText && input.helpText?has_content]\u000a\u0009\u0009\u0009<p class="mb-0 mt-1 text-secondary" id="${fragmentEntryLinkNamespace}-select-input-help-text">${htmlUtil.escape(input.helpText)}</p>\u000a\u0009\u0009[/#if]\u000a\u0009</div>\u000a</div>','const inputElement = document.getElementById(`${fragmentNamespace}-select-input`);\u000aif (layoutMode === ''edit'') {\u000a\u0009inputElement.setAttribute(''disabled'', true);\u000a}','0','{\u000a\u0009"fieldSets": [\u000a\u0009]\u000a}','forms',0,'0','0',3,'{"fieldTypes":["text"]}',NULL,0,20122,'Clarity Admin','2026-04-24 19:27:39.723000')
