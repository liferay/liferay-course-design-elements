INSERT INTO FRAGMENTENTRYLINK VALUES(93,0,'0ad06364-b1a8-61f5-0184-6326e1efb2cc','0ad06364-b1a8-61f5-0184-6326e1efb2cc',32137,32106,16796623585306,20122,'Clarity Admin','2024-05-20 17:59:59.000000','2026-04-24 19:17:26.904000','','','',32111,20031,12,12,'.component-paragraph img {\u000a\u0009max-width: 100%;\u000a}','<div class="clearfix component-paragraph text-break" data-lfr-editable-id="element-text" data-lfr-editable-type="rich-text">\u000a\u0009<p>\u000a\u0009\u0009A paragraph is a self-contained unit of a discourse in writing dealing with\u000a\u0009\u0009a particular point or idea. Paragraphs are usually an expected part of\u000a\u0009\u0009formal writing, used to organize longer prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"sv_SE":"Granska den angivna URL-adressen och f\u00f6rs\u00f6k att uppdatera sidan. Problemet kan vara tillf\u00e4lligt.","defaultValue":"\n\t<p>\n\t\tA paragraph is a self-contained unit of a discourse in writing dealing with\n\t\ta particular point or idea. Paragraphs are usually an expected part of\n\t\tformal writing, used to organize longer prose.\n\t<\/p>\n\n\n","pt_BR":"Revise o endere\u00e7o de URL digitado e tente atualizar a p\u00e1gina. O problema pode ser tempor\u00e1rio.","ja_JP":"\u5165\u529b\u3057\u305f URL \u30a2\u30c9\u30ec\u30b9\u3092\u78ba\u8a8d\u3057\u3066\u304b\u3089\u30da\u30fc\u30b8\u3092\u66f4\u65b0\u3057\u3066\u307f\u3066\u304f\u3060\u3055\u3044\u3002\u3053\u306e\u554f\u984c\u306f\u4e00\u6642\u7684\u306a\u3082\u306e\u3067\u3042\u308b\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002","fr_FR":"V\u00e9rifiez l''URL saisie et essayez d''actualiser la page. Le probl\u00e8me peut \u00eatre temporaire.","hu_HU":"Ellen\u0151rizze a be\u00edrt URL-c\u00edmet, \u00e9s pr\u00f3b\u00e1lja meg friss\u00edteni az oldalt. Lehet, hogy a probl\u00e9ma csak \u00e1tmeneti.","de_DE":"\u00dcberpr\u00fcfen Sie die eingegebene URL-Adr