9"label": "normal",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "nm"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009},\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"label": "large",\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009"value": "lg"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009]\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009]\u000a\u0009\u0009}\u000a\u0009]\u000a}','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"next-button-text":{"defaultValue":"\n\t\t\t\tNext\n\t\t\t","config":{}},"previous-button-text":{"defaultValue":"\n\t\t\t\tPrevious\n\t\t\t","config":{}},"submit-button-text":{"defaultValue":"\n\t\t\tSubmit\n\t\t","en_US":"Next","config":{}}},"com.liferay.fragment.entry.processor.freemarker.FreeMarkerFragmentEntryProcessor":{"buttonType":"primary","submittedEntryStatus":"2","buttonSize":"nm"}}','vhrj',0,'INPUTS-submit-button',3,'2026-04-24 19:17:28.163000',NULL)
