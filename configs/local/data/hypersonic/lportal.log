0a                    "label": "button-text",\u000a                    "localizable": true,\u000a                    "name": "buttonText",\u000a                    "type": "text"\u000a                }\u000a            ],\u000a            "label": "Upload Options"\u000a        },\u000a        {\u000a            "fields": [\u000a                {\u000a                    "defaultValue": "Upload may take a few seconds",\u000a                    "label": "Loading Title",\u000a                    "localizable": true,\u000a                    "name": "loadingTitle",\u000a                    "type": "text"\u000a                },\u000a                {\u000a                    "defaultValue": "Please keep the window open",\u000a                    "label": "Loading Help Text",\u000a                    "localizable": true,\u000a                    "name": "loadingHelpText",\u000a                    "type": "text"\u000a                }\u000a            ],\u000a            "label": "Loading Options"\u000a        }\u000a    ]\u000a}','forms',0,'0','0',3,'{"fieldTypes":["file"]}',NULL,2,20122,'Clarity Admin','2026-04-24 19:24:14.032000')
